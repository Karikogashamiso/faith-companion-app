# =====================================================================
# Environment contract for Faith Companion. Copy what you need into your
# hosting platform's env (Lovable Cloud) or a local .env.local (git-ignored).
#
# SECURITY: never put SECRET values (anything below marked "secret") into the
# tracked .env file. Only the PUBLIC Supabase values belong there. Secrets are
# injected by the hosting platform at runtime.
# =====================================================================

# --- Supabase: PUBLIC (safe in the client, protected by RLS) ---------------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PROJECT_ID=your-project-ref
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key

# --- Supabase: SECRET (server only — bypasses RLS) -------------------------
SUPABASE_SERVICE_ROLE_KEY=          # secret — service role; never expose

# --- AI (Lovable AI Gateway) — SECRET --------------------------------------
LOVABLE_API_KEY=                    # secret — required for all AI features

# --- Stripe web billing — see docs/STRIPE_SETUP.md -------------------------
STRIPE_SECRET_KEY=                  # secret — sk_live_… / sk_test_…
STRIPE_WEBHOOK_SECRET=              # secret — whsec_…
STRIPE_PRICE_WEEKLY=                # price_… (recurring, weekly)
STRIPE_PRICE_MONTHLY=               # price_… (recurring, monthly)
STRIPE_PRICE_ANNUAL=                # price_… (recurring, yearly)

# --- RevenueCat (mobile IAP) webhook — SECRET ------------------------------
REVENUECAT_WEBHOOK_AUTH=            # secret — bearer token shared with RevenueCat

# --- Native app (Capacitor + RevenueCat IAP) — see docs/NATIVE_APP_SETUP.md --
# Public RevenueCat SDK keys (safe in the client). Used only in the native shell.
VITE_RC_IOS_KEY=
VITE_RC_ANDROID_KEY=

# --- Web push — see docs/PUSH_SETUP.md (node scripts/gen-vapid-keys.mjs) ----
VAPID_PUBLIC_KEY=                   # VAPID public key (base64url)
VAPID_PRIVATE_KEY=                  # secret — VAPID private key (base64url)
VITE_VAPID_PUBLIC_KEY=             # SAME as VAPID_PUBLIC_KEY (exposed to client)
VAPID_SUBJECT=mailto:you@yourdomain.com
CRON_SECRET=                        # secret — bearer token for /api/cron/push-due
